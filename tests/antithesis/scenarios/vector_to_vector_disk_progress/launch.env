# Per-scenario settings for ../launch.sh. Only the bits that differ from every
# other scenario live here; the launcher supplies the rest.
SCENARIO_TEST_NAME=vector_to_vector_disk_progress
SCENARIO_DESCRIPTION="disk_v2 drops oversized records without crashing or blocking later writes during a terminal fault-free check"
# No node-level faults. A killed node tears its disk buffer's last data file, and
# the reader's recovery skip increments the same discarded-events counter the
# oversized-drop assertion reads — conflating "oversized dropped" with "recovered
# from a crash". Network partitions and clock jitter (applied by the launcher
# regardless) still stress the buffer's fill/retry/recover path without crashing
# the process. Crash/conservation coverage lives in vector_to_vector_e2e_disk.
SCENARIO_FAULT_NODES=""
